# ---- Kick (kick.com/settings/developer'dan al) ----
KICK_CLIENT_ID=""
KICK_CLIENT_SECRET=""
# OAuth callback — Vercel'de: https://<proje>.vercel.app/api/kick/oauth/callback
KICK_REDIRECT_URI="http://localhost:3000/api/kick/oauth/callback"
KICK_CHANNEL_SLUG="sostevie"

# ---- Gemini (Google AI Studio'dan ücretsiz key) ----
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"

# ---- Upstash Redis (Vercel'de Storage > Redis eklenince otomatik gelir) ----
# Lokal geliştirmede Upstash panelinden REST URL/TOKEN'ı buraya koy.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ---- Admin paneli ----
ADMIN_PASSWORD="degistir-beni"
# Oturum imzası için rastgele uzun string
APP_SECRET="rastgele-uzun-bir-string-uret"

# Cron endpoint'ini korumak için gizli anahtar (GitHub Actions secret'ı ile aynı olmalı)
CRON_SECRET="rastgele-cron-anahtari"

# Uygulamanın public adresi (webhook abonelikleri için)
# Vercel'de: https://<proje>.vercel.app
PUBLIC_BASE_URL="http://localhost:3000"
