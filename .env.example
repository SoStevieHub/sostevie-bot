# ---- Kick (kick.com/settings/developer'dan al) ----
KICK_CLIENT_ID=""
KICK_CLIENT_SECRET=""
# OAuth callback — Vercel'de: https://<proje>.vercel.app/api/kick/oauth/callback
KICK_REDIRECT_URI="http://localhost:3000/api/kick/oauth/callback"
KICK_CHANNEL_SLUG="sostevie"

# ---- LLM sağlayıcı zinciri (sırayla denenir; biri limit yerse diğerine geçer) ----
# En az birini doldur. Hepsi ücretsiz; birden fazlasını eklersen kotalar toplanır, pratikte tükenmez.
GROQ_API_KEY=""
GROQ_MODEL="llama-3.3-70b-versatile"
# console.cerebras.ai (ücretsiz)
CEREBRAS_API_KEY=""
CEREBRAS_MODEL="llama-3.3-70b"
# openrouter.ai (ücretsiz modeller)
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="meta-llama/llama-3.3-70b-instruct:free"
# Opsiyonel: kendi Ollama sunucun (public URL gerekir, Vercel erişebilsin)
OLLAMA_URL=""
OLLAMA_MODEL="llama3.1"

# ---- Tavily (tavily.com ücretsiz key) — @bot sorularında web arama (opsiyonel) ----
# Boş bırakılırsa bot soruları kendi bilgisinden cevaplar. Haberler RSS'ten gelir, anahtar gerekmez.
TAVILY_API_KEY=""

# ---- Upstash Redis (Vercel'de Storage > Redis eklenince otomatik gelir) ----
# Lokal geliştirmede Upstash panelinden REST URL/TOKEN'ı buraya koy.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ---- Admin paneli ----
ADMIN_PASSWORD="degistir-beni"
# Oturum imzası için rastgele uzun string
APP_SECRET="rastgele-uzun-bir-string-uret"

# Cron endpoint'ini korumak için gizli anahtar (GitHub Actions secret'ı ile aynı olmalı)
CRON_SECRET="rastgele-cron-anahtari"

# Uygulamanın public adresi (webhook abonelikleri için)
# Vercel'de: https://<proje>.vercel.app
PUBLIC_BASE_URL="http://localhost:3000"
